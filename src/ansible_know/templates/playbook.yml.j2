---
# playbook.yml -- Ready-to-use playbook for {{ module_name }}
# Generated by AnsibleClaw
#
# Usage:
#   ansible-playbook assets/playbook.yml -i /path/to/inventory.yml --check --diff
#   ansible-playbook assets/playbook.yml -i /path/to/inventory.yml --diff
#
{% if examples and examples_contain_play %}
{{ examples }}
{% elif examples %}
- name: "{{ short_description }}"
  hosts: all
{% if not is_api_module %}
  become: true
{% else %}
  connection: local
  gather_facts: false
{% endif %}
  tasks:
{{ examples | indent(4, first=true) }}
{% else %}
- name: "{{ short_description }}"
  hosts: all
{% if not is_api_module %}
  become: true
{% else %}
  connection: local
  gather_facts: false
{% endif %}
  tasks:
    - name: "Run {{ module_name }}"
      {{ module_name }}:
{% for p in params %}
{% if p.required %}
{% if p.choices %}
        {{ p.name }}: {{ p.choices[0] }}
{% elif p.type == 'bool' %}
        {{ p.name }}: true
{% else %}
        {{ p.name }}: "CHANGEME"
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
